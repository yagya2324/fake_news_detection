# Backend environment variables
# Copy this to .env and fill in your values

# Optional: Google Fact Check API key
# Get one at: https://developers.google.com/fact-check/tools/api
GOOGLE_FACTCHECK_API_KEY=your_api_key_here

# Optional: News API key (newsapi.org)
NEWS_API_KEY=your_news_api_key_here

# Server settings
HOST=127.0.0.1
PORT=8000
